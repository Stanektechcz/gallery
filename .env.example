APP_NAME="Stanektech Gallery"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gallery.stanektech.cz
APP_TIMEZONE=Europe/Prague
APP_LOCALE=cs

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gallery
DB_USERNAME=
DB_PASSWORD=

QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=600

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="gallery@stanektech.cz"
MAIL_FROM_NAME="Stanektech Gallery"

# Web Push is enabled only after VAPID credentials are configured over HTTPS.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://gallery.stanektech.cz/oauth/google/callback
GOOGLE_DRIVE_SCOPE_MODE=managed
GOOGLE_DRIVE_ROOT_FOLDER_NAME="Stanektech Gallery"
GOOGLE_DRIVE_UPLOAD_CHUNK_MB=64

FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
EXIFTOOL_PATH=/usr/bin/exiftool

# Volitelné bezplatné lokální rozpoznání PDF a obrázků s rezervacemi.
# Bez těchto binárek lze údaje vždy vložit nebo opravit ručně.
PDFTOTEXT_PATH=/usr/bin/pdftotext
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANGUAGES=ces+eng

MEDIA_TEMP_DISK=local
MEDIA_VARIANTS_DISK=public

GALLERY_INVITE_ONLY=true
GALLERY_TRASH_RETENTION=30
GALLERY_VARIANT_CACHE_GB=20
GALLERY_VARIANT_CACHE_DAYS=90
GALLERY_MAX_CHUNK_MB=64
GALLERY_MAX_UPLOAD_GB=32
GALLERY_DEFAULT_SPACE="Naše galerie"

GALLERY_OWNER_NAME=Adrian
GALLERY_OWNER_EMAIL=
GALLERY_PARTNER_NAME=Makinka
GALLERY_PARTNER_EMAIL=

GEOCODING_ENABLED=false
GEOCODING_PROVIDER=nominatim

# Timetables + ticket comparison (no private API key required).
# Transitous requires visible attribution and a contact in the User-Agent.
TRANSITOUS_ENABLED=true
TRANSITOUS_URL=https://api.transitous.org/api/v6/plan
TRANSITOUS_GEOCODE_URL=https://api.transitous.org/api/v1/geocode
TRANSITOUS_TIMEOUT=8
REGIOJET_SEARCH_ENABLED=true
TRANSPORT_SEARCH_CACHE_MINUTES=15
TRANSPORT_API_CONTACT=https://gallery.example.com

GOOGLE_CAST_ENABLED=false

GOOGLE_DRIVE_LIVE_TESTS=false

VITE_APP_NAME="${APP_NAME}"
VITE_MAPY_API_KEY=

# Android aplikace (TWA). Podepisovací klíč ani jeho heslo nikdy nepatří do .env ani do Gitu.
ANDROID_APP_PACKAGE=cz.stanektech.maki
ANDROID_APP_VERSION=1.0.0
ANDROID_APP_DISK=local
ANDROID_APP_PATH=mobile/maki-gallery.apk
ANDROID_APP_METADATA_PATH=mobile/maki-gallery.json
# Volitelná alternativa k lokálnímu APK, např. privátní release/CDN odkaz.
ANDROID_APP_DOWNLOAD_URL=
# SHA-256 celého APK pro kontrolu staženého balíčku.
ANDROID_APP_SHA256=
# Otisk veřejného release certifikátu ve formátu AA:BB:… pro Android Digital Asset Links.
ANDROID_APP_SHA256_FINGERPRINT=
